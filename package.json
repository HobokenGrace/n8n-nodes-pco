{
  "name": "@hobokengrace/n8n-nodes-pco",
  "version": "0.2.0",
  "description": "n8n nodes for Planning Center Online",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "n8n-node build && node scripts/copy-assets.mjs",
    "build:watch": "tsc --watch",
    "clean": "node scripts/clean.mjs",
    "dev": "n8n-node dev",
    "format": "prettier --write .",
    "generate": "tsx src/generator/generate.ts",
    "generate:check": "tsx src/generator/checkGenerated.ts",
    "lint": "eslint --config eslint.config.repo.mjs .",
    "lint:fix": "eslint --config eslint.config.repo.mjs . --fix",
    "lint:n8n": "n8n-node lint",
    "openapi:refresh": "tsx src/generator/refreshSnapshots.ts",
    "package:inspect": "node scripts/inspect-package.mjs",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease",
    "release:draft": "node scripts/draft-release.mjs",
    "test": "vitest run"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "planning-center",
    "pco"
  ],
  "license": "MIT",
  "author": {
    "name": "ntcho",
    "email": "ntcho13@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HobokenGrace/n8n-nodes-pco.git"
  },
  "bugs": {
    "url": "https://github.com/HobokenGrace/n8n-nodes-pco/issues"
  },
  "homepage": "https://github.com/HobokenGrace/n8n-nodes-pco#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.30.2",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/PlanningCenterPatApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/generated/api/PlanningCenterApi.node.js",
      "dist/nodes/generated/calendar/PlanningCenterCalendar.node.js",
      "dist/nodes/generated/check-ins/PlanningCenterCheckIns.node.js",
      "dist/nodes/generated/current/PlanningCenterCurrent.node.js",
      "dist/nodes/generated/giving/PlanningCenterGiving.node.js",
      "dist/nodes/generated/groups/PlanningCenterGroups.node.js",
      "dist/nodes/generated/people/PlanningCenterPeople.node.js",
      "dist/nodes/generated/publishing/PlanningCenterPublishing.node.js",
      "dist/nodes/generated/registrations/PlanningCenterRegistrations.node.js",
      "dist/nodes/generated/services/PlanningCenterServices.node.js",
      "dist/nodes/generated/webhooks/PlanningCenterWebhooks.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "@eslint/js": "^9.29.0",
    "@n8n/node-cli": "0.39.3",
    "@types/node": "^22.20.1",
    "eslint": "^9.29.0",
    "inflection": "^3.0.2",
    "n8n-workflow": "*",
    "prettier": "^3.8.3",
    "release-it": "20.2.0",
    "tsx": "^4.20.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^2.1.9"
  }
}
