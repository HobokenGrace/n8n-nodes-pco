{
  "name": "@hobokengrace/n8n-nodes-pco",
  "version": "0.0.0",
  "description": "Generated n8n community nodes for Planning Center Online.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "clean": "node scripts/clean.mjs",
    "format": "prettier --write .",
    "generate": "tsx src/generator/generate.ts",
    "generate:check": "tsx src/generator/checkGenerated.ts",
    "lint": "eslint . --ext .ts",
    "openapi:refresh": "tsx src/generator/refreshSnapshots.ts",
    "test": "vitest run"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "planning-center",
    "pco"
  ],
  "license": "MIT",
  "author": "ntcho <ntcho13@gmail.com>",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.30.2",
  "n8n": {
    "credentials": [
      "dist/credentials/PlanningCenterPatApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/generated/people/PlanningCenterPeople.node.js",
      "dist/nodes/generated/groups/PlanningCenterGroups.node.js",
      "dist/nodes/generated/giving/PlanningCenterGiving.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "@types/node": "^20.19.8",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "inflection": "^3.0.2",
    "n8n-workflow": "*",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
