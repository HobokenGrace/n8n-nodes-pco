{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["credentials/**/*.ts", "nodes/**/*.ts", "src/**/*.ts", "tests/**/*.ts", "index.ts"],
  "exclude": ["dist", "node_modules", ".opencode"]
}
