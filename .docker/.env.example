# Docker image tag. Pin this for repeatable local testing, or use latest while iterating.
N8N_VERSION=latest

# Local n8n URL: http://localhost:${N8N_PORT}
N8N_PORT=5678

# Use a stable key locally so credentials survive container restarts.
# Keep this alphanumeric, or single-quote/escape `$` characters in `.env`.
N8N_ENCRYPTION_KEY=localdevkeylocaldevkeylocaldev12

# Timezone used by n8n schedules and container shell commands.
GENERIC_TIMEZONE=America/New_York
TZ=America/New_York

# Optional local basic auth gate for the n8n UI.
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=local
N8N_BASIC_AUTH_PASSWORD=local
